{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Next.js (dev server)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug Vitest Tests",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vitest", "run"],
      "smartStep": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
