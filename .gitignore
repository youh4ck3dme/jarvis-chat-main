# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# Next.js API routes under app/api/build (negate global gitignore)
!app/api/build/
!app/api/build/**

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# supabase local link cache
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/playwright-report/
/test-results/

# desktop-agent (Python)
desktop-agent/.venv/
desktop-agent/__pycache__/
desktop-agent/**/__pycache__/
desktop-agent/config/api_keys.json
desktop-agent/.env
desktop-agent/.pytest_cache/
desktop-agent/data/