# Alternative name also supported:
GOOGLE_GENERATIVE_AI_API_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Optional: Vercel Blob (if used for file uploads)
BLOB_READ_WRITE_TOKEN=