# Local dev server port (default for this project)
PORT=3141

# Default AI model (Mistral Small — fast HTML build)
DEFAULT_AI_MODEL=mistral/mistral-small-latest
NEXT_PUBLIC_DEFAULT_AI_MODEL=mistral/mistral-small-latest

# Server-side API keys (fallback when client does not send x-*-key headers)
# Set these in Vercel: Project Settings → Environment Variables

MISTRAL_API_KEY=

GEMINI_API_KEY=
# Alternative name also supported:
GOOGLE_GENERATIVE_AI_API_KEY=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Vercel Blob (if used for file uploads)
BLOB_READ_WRITE_TOKEN=