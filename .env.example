# Local dev server port (default for this project)
PORT=3141

# Linear backlog sync — https://linear.app/settings/api
LINEAR_API_KEY=
LINEAR_TEAM_KEY=YOU

# Default AI model (Mistral Small — fast HTML build)
DEFAULT_AI_MODEL=mistral/mistral-small-latest
NEXT_PUBLIC_DEFAULT_AI_MODEL=mistral/mistral-small-latest

# === API KEY HIERARCHY ===
# PRIMARY — web chat default + desktop text tools (memory, code_helper, ...)
MISTRAL_API_KEY=

# SPECIAL — Gemini Live voice (desktop) + multimodal when user picks Gemini in web UI
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# SECONDARY — desktop Mistral fallback (rate limit / code / vision overflow)
MISTRAL_API_KEY_SECONDARY=

# Desktop Mistral models
DESKTOP_MISTRAL_TEXT_MODEL=mistral-small-latest
DESKTOP_MISTRAL_TEXT_MODEL_FALLBACK=mistral-medium-latest
DESKTOP_MISTRAL_CODE_MODEL=codestral-latest
DESKTOP_MISTRAL_VISION_MODEL=pixtral-12b-2409
DESKTOP_AGENT_LLM_PROVIDER=mistral

# === REQUIRED ON VERCEL PRODUCTION ===

# Builder mode password — SERVER ONLY (never NEXT_PUBLIC_)
# Set in Vercel: Project Settings → Environment Variables → Production + Preview
# Required for Builder unlock locally and on Vercel (never commit a real value here).
BUILDER_UNLOCK_PASSWORD=

# Optional builder unlock rate limiting (defaults: 10 attempts / 900 sec)
# BUILDER_UNLOCK_RATE_LIMIT_MAX=10
# BUILDER_UNLOCK_RATE_LIMIT_WINDOW_SEC=900
# BUILDER_UNLOCK_RATE_LIMIT_DISABLED=true

# Optional provider keys (fallback when client does not send x-*-key headers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Vercel Blob (if used for file uploads)
BLOB_READ_WRITE_TOKEN=

# Optional: Supabase session sync (Prompt 16)
# Apply supabase/migrations/001_jarvis_chat_sessions.sql in your Supabase project first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase Auth → Redirect URLs: https://<domain>/auth/callback and http://127.0.0.1:3141/auth/callback

# === Desktop Agent (Local dev only) ===
# Port of the local Python health server
DESKTOP_AGENT_PORT=8765
NEXT_PUBLIC_DESKTOP_AGENT_PORT=8765

# Fixed conversation ID for syncing desktop voice memories
NEXT_PUBLIC_DESKTOP_AGENT_CONVERSATION_ID=desktop-voice-session

# Web application base URL accessed by the desktop agent (localhost dev)
DESKTOP_AGENT_WEB_BASE_URL=http://127.0.0.1:3141

# OpenRouter API key for advanced coding actions (code_helper, dev_agent)
OPENROUTER_API_KEY=
